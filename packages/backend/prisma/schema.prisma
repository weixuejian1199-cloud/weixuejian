// ============================================================
// Enterprise Workstation - Phase 1 Schema
// Prisma 6.x / PostgreSQL
// AI/System Layer + Customer Service MVP + Foundation
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────
// Enums
// ──────────────────────────────────────────

enum AgentType {
  master
  finance
  operation
  settlement
  report
  customer_service
  system
  tool
}

enum MessageRole {
  user
  assistant
  tool
  system
}

enum CSSessionStatus {
  ai_handling          // AI 初步对话处理
  ai_judging           // AI 退货判断中
  pending_human_review // 人工待确认 AI 建议
  escalated            // 已升级（高优先级人工处理）
  human_queue          // 等待人工客服接单
  human_handling       // 人工处理中
  resolved             // 已解决
  closed               // 已关闭
}

enum CSMessageSender {
  buyer
  ai
  human_agent
}

enum CSTicketType {
  refund
  exchange
  return_goods
  complaint
  other
}

enum CSTicketStatus {
  pending                    // 待处理
  ai_judging                 // AI 判断中
  awaiting_human_confirmation // 等待人工确认 AI 判断
  approved                   // 已批准
  rejected                   // 已拒绝
  processing                 // 执行中
  completed                  // 已完成
}

enum AciDecision {
  APPROVE
  REJECT
  REJECT_WITH_APPEAL
  ESCALATE
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// ──────────────────────────────────────────
// Foundation Layer
// ──────────────────────────────────────────

model Tenant {
  id             String    @id @default(uuid())
  name           String
  slug           String    @unique
  plan           String    @default("free")
  planExpiresAt  DateTime?
  maxUsers       Int       @default(10)
  maxShops       Int       @default(5)
  aiQuotaMonthly      Int       @default(1000)
  aiQuotaDaily        Int       @default(100000)
  aiBudgetMonthly     Decimal   @default(100.00) @db.Decimal(10, 2)
  aiAlertThreshold    Decimal   @default(0.80)   @db.Decimal(3, 2)
  aiDowngradeThreshold Decimal  @default(0.90)   @db.Decimal(3, 2)
  status         String    @default("active")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  users                   User[]
  roles                   Role[]
  refreshTokens           RefreshToken[]
  conversations           Conversation[]
  messages                Message[]
  auditLogs               AuditLog[]
  notifications           Notification[]
  customerServiceSessions CustomerServiceSession[]
  customerServiceMessages CustomerServiceMessage[]
  customerServiceTickets  CustomerServiceTicket[]
  aiJudgmentRecords       AiJudgmentRecord[]
  departments             Department[]
  userShops               UserShop[]
  shops                   Shop[]
  erpConnections          ERPConnection[]
  syncLogs                SyncLog[]
  payments                Payment[]
  afterSales              AfterSale[]
  toolInstances           ToolInstance[]
  toolDefinitions         ToolDefinition[]
  confirmationRecords     ConfirmationRecord[]
  aiUsageRecords          AiUsageRecord[]

  @@map("tenants")
}

model User {
  id           String    @id @default(uuid())
  tenantId     String
  phone        String
  name         String
  avatarUrl    String?
  wechatOpenid String?
  wecomUserid  String?
  roleId       String
  departmentId String?
  status       String    @default("active")
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  role       Role        @relation(fields: [roleId], references: [id], onDelete: Restrict)
  department Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  refreshTokens     RefreshToken[]
  conversations     Conversation[]
  messages          Message[]
  auditLogs         AuditLog[]
  notifications     Notification[]
  assignedSessions  CustomerServiceSession[] @relation("AssignedUser")
  aiJudgmentRecords AiJudgmentRecord[]
  userShops         UserShop[]

  @@unique([tenantId, phone])
  @@index([tenantId])
  @@map("users")
}

model Role {
  id          String    @id @default(uuid())
  tenantId    String
  code        String
  name        String
  permissions Json
  dataScope   String    @default("own")
  isSystem    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  users  User[]

  @@unique([tenantId, code])
  @@map("roles")
}

model RefreshToken {
  id        String    @id @default(uuid())
  tenantId  String
  userId    String
  tokenHash String
  deviceId  String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId])
  @@index([tenantId, tokenHash])
  @@index([tenantId, expiresAt])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ──────────────────────────────────────────
// AI & System Layer
// ──────────────────────────────────────────

model Conversation {
  id             String    @id @default(uuid())
  tenantId       String
  userId         String
  agentType      AgentType
  title          String?
  contextSummary String?
  tokenUsed      Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]
  confirmationRecords ConfirmationRecord[]

  @@index([tenantId, userId, createdAt])
  @@map("conversations")
}

// ──────────────────────────────────────────
// AI Cost Monitoring (Phase 2, BL-022)
// ──────────────────────────────────────────

/// AI用量记录：每次AI API调用一条，用于成本监控仪表盘
model AiUsageRecord {
  id               String    @id @default(cuid())
  tenantId         String
  userId           String
  conversationId   String?
  agentType        AgentType
  model            String
  promptTokens     Int
  completionTokens Int
  totalTokens      Int
  costYuan         Decimal   @db.Decimal(10, 6)
  wasDowngraded    Boolean   @default(false)
  originalModel    String?
  createdAt        DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([tenantId, createdAt])
  @@index([tenantId, userId, createdAt])
  @@index([tenantId, agentType, createdAt])
  @@map("ai_usage_records")
}

model Message {
  id             String      @id @default(uuid())
  tenantId       String
  conversationId String
  userId         String
  role           MessageRole
  content        String      @db.Text
  toolCalls      Json?
  toolResults    Json?
  createdAt      DateTime    @default(now())
  deletedAt      DateTime?

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([tenantId, userId, createdAt])
  @@map("messages")
}

/// 审计日志：不可变记录，无deletedAt（设计决策：审计数据不允许软删除）
model AuditLog {
  id           BigInt   @id @default(autoincrement())
  tenantId     String
  userId       String
  action       String
  resourceType String
  resourceId   String?
  beforeData   Json?
  afterData    Json?
  ipAddress    String?
  createdAt    DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([tenantId, createdAt])
  @@index([tenantId, userId, action])
  @@index([createdAt])
  @@map("audit_logs")
}

model Notification {
  id       String   @id @default(uuid())
  tenantId String
  userId   String
  type     String
  channel  String
  title    String
  content  String
  isRead    Boolean  @default(false)
  sentAt    DateTime @default(now())
  readAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, isRead])
  @@map("notifications")
}

// ──────────────────────────────────────────
// Customer Service MVP
// ──────────────────────────────────────────

model CustomerServiceSession {
  id             String          @id @default(uuid())
  tenantId       String
  channelType    String
  channelId      String
  externalUserId String
  buyerName      String?
  orderId        String?
  category       String          @default("general")
  status         CSSessionStatus @default(ai_handling)
  assignedUserId String?
  aiSummary      String?
  satisfaction   Int?
  resolvedAt     DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?

  tenant       Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  assignedUser User?  @relation("AssignedUser", fields: [assignedUserId], references: [id], onDelete: SetNull)

  messages          CustomerServiceMessage[]
  tickets           CustomerServiceTicket[]
  aiJudgmentRecords AiJudgmentRecord[]

  @@index([tenantId, status])
  @@index([tenantId, channelType, externalUserId])
  @@index([tenantId, assignedUserId])
  @@index([tenantId, createdAt])
  @@map("customer_service_sessions")
}

model CustomerServiceMessage {
  id        String          @id @default(uuid())
  tenantId  String
  sessionId String
  sender    CSMessageSender
  content   String          @db.Text
  msgType   String          @default("text")
  metadata  Json?
  createdAt DateTime        @default(now())
  deletedAt DateTime?

  tenant  Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  session CustomerServiceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@index([tenantId, createdAt])
  @@map("customer_service_messages")
}

model CustomerServiceTicket {
  id              String         @id @default(uuid())
  tenantId        String
  sessionId       String
  orderId         String?
  afterSaleId     String?
  aiJudgmentId    String?
  type            CSTicketType
  aiDecision      Json
  humanDecision   Json?
  humanReviewedAt DateTime?
  humanComments   String?        @db.Text
  status          CSTicketStatus @default(pending)
  processedBy     String?
  processedAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?

  tenant      Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  session     CustomerServiceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  aiJudgment  AiJudgmentRecord?      @relation("TicketJudgment", fields: [aiJudgmentId], references: [id], onDelete: SetNull)

  aiJudgmentRecords AiJudgmentRecord[] @relation("TicketJudgmentHistory")

  @@index([tenantId, status])
  @@index([tenantId, sessionId])
  @@index([tenantId, aiJudgmentId])
  @@map("customer_service_tickets")
}

// ──────────────────────────────────────────
// AI Judgment Record (v2.3)
// ──────────────────────────────────────────

model AiJudgmentRecord {
  id                String      @id @default(uuid())
  tenantId          String
  sessionId         String?
  ticketId          String?
  orderId           String?
  userId            String
  judgmentType      String
  decision          AciDecision
  reason            String      @db.Text
  reasonForCustomer String?
  riskLevel         RiskLevel
  confidence        Decimal     @db.Decimal(3, 2)
  triggeredRules    Json
  context           Json
  executionAllowed  Boolean     @default(false)
  disclaimer        String?     @db.Text
  processingTimeMs  Int?
  modelUsed         String?
  createdAt         DateTime    @default(now())
  deletedAt         DateTime?

  tenant  Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  session CustomerServiceSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  ticket  CustomerServiceTicket?  @relation("TicketJudgmentHistory", fields: [ticketId], references: [id], onDelete: SetNull)
  user    User                    @relation(fields: [userId], references: [id], onDelete: Restrict)

  primaryTicket CustomerServiceTicket[] @relation("TicketJudgment")
  afterSales    AfterSale[]

  @@index([tenantId, createdAt])
  @@index([tenantId, judgmentType, createdAt])
  @@index([tenantId, decision])
  @@index([tenantId, orderId])
  @@index([tenantId, sessionId])
  @@index([tenantId, riskLevel, createdAt])
  @@index([tenantId, confidence, createdAt])
  @@map("ai_judgment_records")
}

// ──────────────────────────────────────────
// Enums (Phase 1 Extension)
// ──────────────────────────────────────────

enum Platform {
  taobao
  jd
  douyin
  pinduoduo
  wechat
  self
}

enum ErpType {
  jushuitan
  wangdiantong
  ztdy_open
  manual
}

enum SyncType {
  full
  incremental
  manual
}

enum SyncEntity {
  order
  product
  user
  supplier
}

enum SyncStatus {
  pending
  running
  success
  failed
  partial
}

enum PaymentMethod {
  wechat
  alipay
  bank
  balance
}

enum PaymentStatus {
  pending
  processing
  success
  failed
  refunding
  refunded
  closed
}

enum AfterSaleType {
  return_refund
  refund_only
  exchange
}

enum AfterSaleStatus {
  as_pending
  ai_judged
  human_review
  approved
  rejected
  as_processing
  completed
  cancelled
}

enum ConfirmationStatus {
  pending
  confirmed
  rejected
  expired
  cancelled
}

enum ToolCategory {
  health
  finance
  operation
  cs
  analytics
}

enum ShopStatus {
  active
  inactive
  suspended
}

enum DepartmentStatus {
  dept_active
  dept_inactive
}

// ──────────────────────────────────────────
// Foundation Layer Extension
// ──────────────────────────────────────────

model Department {
  id        String           @id @default(cuid())
  tenantId  String
  name      String
  parentId  String?
  path      String // 物化路径如 /1/2/3
  level     Int
  sortOrder Int              @default(0)
  status    DepartmentStatus @default(dept_active)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  deletedAt DateTime?

  tenant   Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  parent   Department?  @relation("DepartmentTree", fields: [parentId], references: [id], onDelete: Restrict)
  children Department[] @relation("DepartmentTree")
  users    User[]

  @@unique([tenantId, name, parentId])
  @@index([tenantId, path])
  @@index([parentId])
  @@map("departments")
}

model UserShop {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  shopId    String
  role      String   @default("operator") // owner/manager/operator
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  shop   Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, shopId])
  @@index([tenantId, userId])
  @@index([tenantId, shopId])
  @@map("user_shops")
}

// ──────────────────────────────────────────
// Business Layer (Phase 1 Minimum)
// ──────────────────────────────────────────

model Shop {
  id             String     @id @default(cuid())
  tenantId       String
  name           String
  platform       Platform
  platformShopId String
  status         ShopStatus @default(active)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  deletedAt      DateTime?

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  userShops UserShop[]

  @@unique([tenantId, platformShopId])
  @@map("shops")
}

model ERPConnection {
  id           String    @id @default(cuid())
  tenantId     String
  erpType      ErpType
  name         String
  credentials  Json // 加密JSON
  syncConfig   Json // 同步频率/范围
  status       String    @default("active") // active/inactive/error
  lastSyncAt   DateTime?
  errorMessage String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  syncLogs SyncLog[]

  @@unique([tenantId, erpType, name])
  @@map("erp_connections")
}

model SyncLog {
  id               String     @id @default(cuid())
  tenantId         String
  erpConnectionId  String
  syncType         SyncType
  entity           SyncEntity
  status           SyncStatus @default(pending)
  recordsTotal     Int        @default(0)
  recordsProcessed Int        @default(0)
  recordsFailed    Int        @default(0)
  startedAt        DateTime   @default(now())
  completedAt      DateTime?
  errorMessage     String?
  metadata         Json?
  createdAt        DateTime   @default(now())

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  erpConnection ERPConnection @relation(fields: [erpConnectionId], references: [id], onDelete: Cascade)

  @@index([tenantId, erpConnectionId])
  @@index([tenantId, status])
  @@map("sync_logs")
}

// ──────────────────────────────────────────
// Payment Layer (Phase 1b)
// ──────────────────────────────────────────

model Payment {
  id              String        @id @default(cuid())
  tenantId        String
  orderId         String // 外部订单ID字符串
  orderSource     String // mall/erp
  paymentMethod   PaymentMethod
  amount          Decimal       @db.Decimal(12, 2)
  status          PaymentStatus @default(pending)
  transactionId   String? // 第三方交易号
  gatewayResponse Json?
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@unique([tenantId, transactionId])
  @@index([tenantId, orderId])
  @@index([tenantId, status, createdAt])
  @@map("payments")
}

model AfterSale {
  id              String          @id @default(cuid())
  tenantId        String
  orderId         String // 外部订单ID
  orderSource     String // mall/erp
  userId          String
  type            AfterSaleType
  status          AfterSaleStatus @default(as_pending)
  reason          String?         @db.Text
  aiJudgmentId    String?
  humanReviewerId String?
  humanDecision   String?
  refundAmount    Decimal?        @db.Decimal(12, 2)
  refundPaymentId String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?

  tenant     Tenant            @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  aiJudgment AiJudgmentRecord? @relation(fields: [aiJudgmentId], references: [id], onDelete: SetNull)

  @@index([tenantId, orderId])
  @@index([tenantId, userId, status])
  @@index([tenantId, status, createdAt])
  @@map("after_sales")
}

// ──────────────────────────────────────────
// Confirmation & Decision Replay (Phase 2, BL-023 / ADR-019)
// ──────────────────────────────────────────

/// 操作确认记录：AI生成确认请求 → 用户确认/拒绝 → 记录完整决策链
model ConfirmationRecord {
  id                 String             @id @default(uuid())
  tenantId           String
  userId             String
  conversationId     String?
  agentType          AgentType          @default(master)

  // 确认请求
  title              String             /// 操作标题，如"退货审批：订单#12345"
  description        String             @db.Text /// 操作描述
  riskLevel          RiskLevel          @default(LOW)
  operationType      String             /// 操作类型：refund/price_change/shelf_toggle/order_cancel等
  resourceType       String?            /// 关联资源类型：order/product/supplier
  resourceId         String?            /// 关联资源ID
  changeDetails      Json               /// 变更明细：{before, after, fields}
  expiresAt          DateTime?          /// 确认超时时间

  // 用户响应
  status             ConfirmationStatus @default(pending)
  respondedAt        DateTime?
  responseReason     String?            @db.Text /// 用户拒绝理由

  // AI决策链回放（核心：完整还原决策过程）
  aiInput            Json               /// AI收到的原始输入/上下文
  aiRecommendation   String             @db.Text /// AI给出的建议（如"建议批准"）
  triggeredRules     Json               /// 触发的规则列表 [{ruleId, ruleName, result, weight}]
  evidence           Json               /// 决策证据 [{type, source, data, timestamp}]

  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  deletedAt          DateTime?

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([tenantId, status])
  @@index([tenantId, userId, createdAt])
  @@index([tenantId, operationType, createdAt])
  @@index([tenantId, resourceType, resourceId])
  @@index([tenantId, riskLevel, status])
  @@map("confirmation_records")
}

// ──────────────────────────────────────────
// Tool Layer (Phase 2 schema pre-definition)
// ──────────────────────────────────────────

model ToolDefinition {
  id           String       @id @default(cuid())
  tenantId     String
  name         String
  displayName  String
  description  String?      @db.Text
  category     ToolCategory
  version      String
  configSchema Json? // Zod schema定义
  permissions  String[]
  modelConfig  Json? // 模型/temperature等
  isBuiltin    Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?

  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  instances ToolInstance[]

  @@unique([tenantId, name, version])
  @@index([tenantId])
  @@map("tool_definitions")
}

model ToolInstance {
  id               String   @id @default(cuid())
  tenantId         String
  toolDefinitionId String
  config           Json?
  status           String   @default("active") // active/inactive/error
  activatedAt      DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  deletedAt        DateTime?

  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  toolDefinition ToolDefinition @relation(fields: [toolDefinitionId], references: [id], onDelete: Cascade)

  @@unique([tenantId, toolDefinitionId])
  @@map("tool_instances")
}
