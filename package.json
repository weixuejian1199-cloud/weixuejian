{
  "name": "enterprise-workstation",
  "version": "0.1.0",
  "private": true,
  "description": "企业AI工作站 - 对话即一切的企业级AI操作系统",
  "scripts": {
    "dev": "pnpm --filter backend dev",
    "build": "pnpm --filter backend build",
    "lint": "eslint 'packages/**/*.{ts,tsx}'",
    "lint:fix": "eslint 'packages/**/*.{ts,tsx}' --fix",
    "format": "prettier --write 'packages/**/*.{ts,tsx,json}'",
    "format:check": "prettier --check 'packages/**/*.{ts,tsx,json}'",
    "test": "pnpm --filter backend test",
    "db:migrate": "pnpm --filter backend prisma:migrate",
    "db:seed": "pnpm --filter backend prisma:seed"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@prisma/client",
      "@prisma/engines",
      "@swc/core",
      "@tarojs/binding",
      "@tarojs/cli",
      "esbuild",
      "msgpackr-extract",
      "prisma"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "typescript": "~5.7.3",
    "typescript-eslint": "^8.57.2"
  }
}
