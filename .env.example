# === 基础 ===
NODE_ENV=development
PORT=3000

# === 域名 ===
API_DOMAIN=api.cebrenis.com
APP_DOMAIN=app.cebrenis.com

# === CORS 白名单（逗号分隔） ===
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# === 数据库 ===
DATABASE_URL=postgresql://postgres:postgres_local_dev@localhost:5432/enterprise_workstation
DB_PASSWORD=postgres_local_dev

# === Redis（Docker映射端口6380，支持密码） ===
REDIS_URL=redis://:redis_local_dev@localhost:6380
REDIS_PASSWORD=redis_local_dev

# === JWT ===
# Phase 1: HS256 + JWT_SECRET（至少32字符）
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
# Phase 1b: 升级 RS256 密钥对
# JWT_PRIVATE_KEY_PATH=./keys/private.pem
# JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# === 日志级别（可选：fatal/error/warn/info/debug/trace） ===
LOG_LEVEL=debug

# === 微信小程序 ===
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# === 阿里云 ===
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_OSS_BUCKET=
ALIYUN_OSS_REGION=oss-cn-beijing

# === AI（百炼） ===
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen3-coder-plus

# === 商城 API（ztdy-open） ===
ZTDY_API_BASE_URL=
ZTDY_API_KEY=

# === ERP（聚水潭） ===
JST_APP_KEY=
JST_APP_SECRET=

# === 限流配置（可选，有默认值） ===
# 租户级：同一租户所有用户共享
RATE_LIMIT_TENANT_MAX=100
RATE_LIMIT_TENANT_WINDOW_MS=60000
# 用户级：单个用户独立配额
RATE_LIMIT_USER_MAX=30
RATE_LIMIT_USER_WINDOW_MS=60000
# AI接口专项：/api/v1/ai/* 路径
RATE_LIMIT_AI_MAX=10
RATE_LIMIT_AI_WINDOW_MS=60000

# === 飞书 Bridge（Claude Code 飞书号1） ===
FEISHU_APP_ID=
FEISHU_APP_SECRET=
PROJECT_DIR=.
BRIDGE_TIMEOUT_MS=180000
BRIDGE_MAX_TURNS=5
BRIDGE_RATE_LIMIT=10

# === 启元 Agent 系统 ===
BOSS_CHAT_ID=                      # 老板飞书chatId（告警+日报发送目标）
BACKEND_HEALTH_URL=                # 后端健康检查地址，如 http://ip:3000/health
INSPECTOR_INTERVAL_MS=300000       # 巡检间隔（毫秒），默认5分钟
DAILY_REPORT_HOUR=8                # 日报发送时间（24h），默认08:00

# === 启序（全局 Claude Code Bot） ===
QIXU_APP_ID=                      # 启序飞书应用 ID
QIXU_APP_SECRET=                  # 启序飞书应用密钥（去后台重新生成）

# === 数据库备份 ===
BACKUP_DIR=/data/backups
# 日备份保留天数（默认30天）
DAILY_RETENTION_DAYS=30
# 月备份保留天数（默认365天=1年）
MONTHLY_RETENTION_DAYS=365

# === 阿里云 OSS 备份存储 ===
# OSS_BUCKET 为空时跳过上传，仅保留本地备份
OSS_BUCKET=
OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
OSS_BACKUP_PREFIX=backups

# === 企微 Webhook 告警（Phase 2 接入） ===
WECOM_WEBHOOK_URL=
