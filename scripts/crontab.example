# ============================================================
# 企业AI工作站 — 备份定时任务配置
#
# 安装方法：
#   1. 编辑当前用户的 crontab:  crontab -e
#   2. 将下面的内容粘贴进去
#   3. 保存退出
#
# 或者直接导入：
#   crontab scripts/crontab.example
#
# 查看已安装的定时任务：
#   crontab -l
#
# 日志查看：
#   tail -f /data/backups/logs/backup.log
# ============================================================

# ---- 环境变量 ----
# cron 执行环境没有用户的 shell 环境变量，需要在这里声明
SHELL=/bin/bash
PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

# ---- 每天凌晨 3:00 执行全量备份 ----
# 分 时 日 月 周  命令
# Docker 方式（推荐）：在 postgres 容器内执行 pg_dump
0 3 * * * docker exec enterprise-workstation-postgres-1 bash -c 'DB_PASSWORD="${POSTGRES_PASSWORD}" DB_HOST=localhost BACKUP_DIR=/data/backups /scripts/backup.sh' >> /data/backups/logs/backup.log 2>&1

# 宿主机方式（如果 pg_dump 安装在宿主机）：
# 0 3 * * * cd /opt/enterprise-workstation && source .env && bash scripts/backup.sh >> /data/backups/logs/backup.log 2>&1

# ---- 每周日 4:00 清理 WAL 归档（可选） ----
# 保留最近 7 天的 WAL 文件，更早的由全量备份覆盖
# 0 4 * * 0 find /data/wal-archive -name "*.gz" -mtime +7 -delete >> /data/backups/logs/backup.log 2>&1
